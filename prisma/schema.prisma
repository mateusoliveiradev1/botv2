// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id
  username  String?
  joinedAt  DateTime @default(now())
  
  xp        UserXP?
  warnings  Warning[]
  mercenary MercenaryProfile?
  missions  MissionProgress[]
  economy   UserEconomy?
  inventory UserInventory[]
}

model UserXP {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id])
  xp            Int      @default(0)
  level         Int      @default(1)
  lastMessageAt DateTime @default(now())
}

model Warning {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  moderatorId String
  guildId     String
  reason      String
  createdAt   DateTime @default(now())
}

model MercenaryProfile {
  userId    String              @id
  user      User                @relation(fields: [userId], references: [id])
  contracts Int                 @default(0)
  
  // Reputation Scores
  repComms   Float @default(0)
  repGunplay Float @default(0)
  repSense   Float @default(0)
  repSynergy Float @default(0)
  repCount   Int   @default(0)

  history   MercenaryContract[]
}

model MercenaryContract {
  id          Int      @id @default(autoincrement())
  mercenaryId String
  mercenary   MercenaryProfile @relation(fields: [mercenaryId], references: [userId])
  
  clanName    String
  feedback    String?
  date        DateTime @default(now())
}

model MissionProgress {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  missionId String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  
  @@unique([userId, missionId])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  guildId     String
  type        String
  title       String
  description String
  executorId  String?
  targetId    String?
  createdAt   DateTime @default(now())
}

model SystemState {
  key   String @id
  value String
}

model TempChannel {
  id        String   @id // Channel ID
  ownerId   String
  guildId   String
  createdAt DateTime @default(now())
}

model ServerBackup {
  id        String   @id @default(uuid())
  guildId   String
  createdAt DateTime @default(now())
  type      String   @default("AUTO") // AUTO or MANUAL
  data      String // SQLite Compat
  size      Int
}

model UserEconomy {
  userId    String    @id
  user      User      @relation(fields: [userId], references: [id])
  balance   Int       @default(0)
  lastDaily DateTime?
}

model UserInventory {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  itemId     String
  acquiredAt DateTime @default(now())
}

model Giveaway {
  id          String   @id @default(uuid())
  guildId     String
  channelId   String
  messageId   String   @unique
  hostId      String
  prize       String
  description String?
  winnersCount Int     @default(1)
  status      String   @default("ACTIVE") // ACTIVE, ENDED
  type        String   @default("MANUAL") // MANUAL, COINS, XP
  amount      Int?     // Quantidade de Moedas ou XP
  createdAt   DateTime @default(now())
  endsAt      DateTime
  
  participants GiveawayParticipant[]
}

model GiveawayParticipant {
  id         Int      @id @default(autoincrement())
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId     String
  joinedAt   DateTime @default(now())

  @@unique([giveawayId, userId])
}

// --- INTELLIGENCE SYSTEM (TACTICS) ---

model WeaponMeta {
  name              String   @id
  type              String   // AR, DMR, SR, SMG
  ammo              String
  damage            Int
  rpm               Int?     // Rounds Per Minute (for TTK calc)
  tier              String   // S, A, B, C, GOD
  description       String
  meta_notes        String
  pick_rate         Float    @default(0)
  win_rate          Float    @default(0)
  
  // Advanced Stats (V2)
  ttk_vest2         String?  // Nullable because some weapons (like SR) might not have DPS
  bullet_velocity   Int?
  recoil_control    String?
  attachments_guide String?

  updatedAt         DateTime @updatedAt
}

model MapStrategy {
  name        String   @id
  size        String
  image       String
  features    String[] // Stored as array, Prisma supports this on Postgres
  locations   Json     // Stored as JSON for flexibility
  updatedAt   DateTime @updatedAt
}

model ProRotation {
  id             Int      @id @default(autoincrement())
  team           String
  map            String
  drop_spot      String
  strategy       String
  signature_move String
  
  // Advanced Playbook (V2)
  playstyle      String?
  composition    String?
  rotation_path  String?

  updatedAt      DateTime @updatedAt

  @@unique([team, map])
}
