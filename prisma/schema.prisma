// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id
  username  String?
  joinedAt  DateTime @default(now())
  
  xp        UserXP?
  warnings  Warning[]
  mercenary MercenaryProfile?
  missions  MissionProgress[]
  economy   UserEconomy?
  inventory UserInventory[]
  
  // Competitive Module
  compWallet CompWallet?
  compTeams  CompTeamMember[]
  compLedger CompLedger[]
  compTx     CompTransaction[]
}

model UserXP {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id])
  xp            Int      @default(0)
  level         Int      @default(1)
  lastMessageAt DateTime @default(now())
}

model Warning {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  moderatorId String
  guildId     String
  reason      String
  createdAt   DateTime @default(now())
}

model MercenaryProfile {
  userId    String              @id
  user      User                @relation(fields: [userId], references: [id])
  contracts Int                 @default(0)
  
  // Reputation Scores
  repComms   Float @default(0)
  repGunplay Float @default(0)
  repSense   Float @default(0)
  repSynergy Float @default(0)
  repCount   Int   @default(0)

  history   MercenaryContract[]
}

model MercenaryContract {
  id          Int      @id @default(autoincrement())
  mercenaryId String
  mercenary   MercenaryProfile @relation(fields: [mercenaryId], references: [userId])
  
  clanName    String
  feedback    String?
  date        DateTime @default(now())
}

model MissionProgress {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  missionId String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  
  @@unique([userId, missionId])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  guildId     String
  type        String
  title       String
  description String
  executorId  String?
  targetId    String?
  createdAt   DateTime @default(now())
}

model SystemState {
  key   String @id
  value String
}

model TempChannel {
  id        String   @id // Channel ID
  ownerId   String
  guildId   String
  createdAt DateTime @default(now())
}

model ServerBackup {
  id        String   @id @default(uuid())
  guildId   String
  createdAt DateTime @default(now())
  type      String   @default("AUTO") // AUTO or MANUAL
  data      String // SQLite Compat
  size      Int
}

model UserEconomy {
  userId    String    @id
  user      User      @relation(fields: [userId], references: [id])
  balance   Int       @default(0)
  lastDaily DateTime?
}

model UserInventory {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  itemId     String
  acquiredAt DateTime @default(now())
}

model Giveaway {
  id          String   @id @default(uuid())
  guildId     String
  channelId   String
  messageId   String   @unique
  hostId      String
  prize       String
  description String?
  winnersCount Int     @default(1)
  status      String   @default("ACTIVE") // ACTIVE, ENDED
  type        String   @default("MANUAL") // MANUAL, COINS, XP
  amount      Int?     // Quantidade de Moedas ou XP
  createdAt   DateTime @default(now())
  endsAt      DateTime
  
  participants GiveawayParticipant[]
}

model GiveawayParticipant {
  id         Int      @id @default(autoincrement())
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId     String
  joinedAt   DateTime @default(now())

  @@unique([giveawayId, userId])
}

// --- INTELLIGENCE SYSTEM (TACTICS) ---

model WeaponMeta {
  name              String   @id
  type              String   // AR, DMR, SR, SMG
  ammo              String
  damage            Int
  rpm               Int?     // Rounds Per Minute (for TTK calc)
  tier              String   // S, A, B, C, GOD
  description       String
  meta_notes        String
  pick_rate         Float    @default(0)
  win_rate          Float    @default(0)
  
  // Advanced Stats (V2)
  ttk_vest2         String?  // Nullable because some weapons (like SR) might not have DPS
  bullet_velocity   Int?
  recoil_control    String?
  attachments_guide String?

  updatedAt         DateTime @updatedAt
}

model MapStrategy {
  name        String   @id
  size        String
  image       String
  features    String[] // Stored as array, Prisma supports this on Postgres
  locations   Json     // Stored as JSON for flexibility
  updatedAt   DateTime @updatedAt
}

model ProRotation {
  id             Int      @id @default(autoincrement())
  team           String
  map            String
  drop_spot      String
  strategy       String
  signature_move String
  
  // Advanced Playbook (V2)
  playstyle      String?
  composition    String?
  rotation_path  String?

  updatedAt      DateTime @updatedAt

  @@unique([team, map])
}

// --- COMPETITIVE SYSTEM (V2) ---

model CompWallet {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id])
  credits     Int      @default(0) // R$ in cents (e.g. 500 = R$5.00)
  winnings    Int      @default(0) // Prize money in cents
  
  updatedAt   DateTime @updatedAt
}

model CompTeam {
  id        String   @id @default(uuid())
  name      String   
  captainId String
  logoUrl   String?
  roleId    String?  // Discord Role ID
  mode      String   // SQUAD, DUO
  
  createdAt DateTime @default(now())
  
  members   CompTeamMember[]
  entries   CompMatchEntry[]
}

model CompTeamMember {
  id        Int      @id @default(autoincrement())
  teamId    String
  team      CompTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  joinedAt  DateTime @default(now())

  @@unique([teamId, userId])
}

model CompMatch {
  id             String   @id @default(uuid())
  tournamentId   String?
  tournament     CompTournament? @relation(fields: [tournamentId], references: [id])
  
  status         String   @default("OPEN") // OPEN, LOCKED, LIVE, FINALIZED
  mode           String   // SQUAD, DUO, SOLO
  teamSize       Int      @default(1)
  
  entryCost      Int      @default(0) // Cost in cents
  prizePool      Int      @default(0) // Total pool in cents
  payoutStrategy String   @default("DEFAULT") // SOLO_TOP16, SQUAD_TOP4, etc.
  
  maxTeams       Int      @default(100)
  
  channelCategoryId String? // Discord Category ID
  
  createdAt      DateTime @default(now())
  startedAt      DateTime?
  endedAt        DateTime?
  
  entries        CompMatchEntry[]
  results        CompMatchResult[]
}

model CompMatchEntry {
  id        Int      @id @default(autoincrement())
  matchId   String
  match     CompMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  teamId    String?
  team      CompTeam? @relation(fields: [teamId], references: [id])
  
  // For Solo matches, we might just use CompTeam with 1 member or add userId here?
  // Following the plan: Solo creates a "Team" of 1 automatically or we handle it here.
  // Let's stick to Team for consistency (Team of 1 for Solo).
  
  createdAt DateTime @default(now())
  paid      Boolean  @default(false)

  @@unique([matchId, teamId])
}

model CompMatchResult {
  id        Int      @id @default(autoincrement())
  matchId   String
  match     CompMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  teamId    String
  placement Int
  kills     Int      @default(0)
  score     Int      @default(0) // For tournaments
  prize     Int      @default(0) // Amount won in cents
}

model CompTournament {
  id        String   @id @default(uuid())
  title     String
  status    String   @default("PLANNED") // PLANNED, ACTIVE, FINISHED
  format    String   // LEAGUE, KNOCKOUT
  
  matches   CompMatch[]
  
  createdAt DateTime @default(now())
}

model CompTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  type        String   // DEPOSIT, WITHDRAW, ENTRY_FEE, PRIZE
  amount      Int      // Cents
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED
  
  externalId  String?  @unique // OpenPix ID
  qrCode      String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompLedger {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  type        String   // CREDIT_IN, CREDIT_OUT, PRIZE_IN, WITHDRAW_OUT
  amount      Int
  description String
  balanceAfter Int
  
  createdAt   DateTime @default(now())
}
